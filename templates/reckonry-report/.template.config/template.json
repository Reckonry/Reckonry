{
  "$schema": "http://json.schemastore.org/template",
  "author": "Reckonry",
  "classifications": [ "Reckonry", "Plugin", "Report" ],
  "identity": "Reckonry.Templates.Report",
  "name": "Reckonry Report Plugin",
  "shortName": "reckonry-report",
  "sourceName": "SampleReport",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "reckonryRoot": {
      "type": "parameter",
      "datatype": "text",
      "defaultValue": "../../../..",
      "replaces": "../../../..",
      "description": "Relative or absolute path from generated project files to the Reckonry repository root."
    }
  }
}
