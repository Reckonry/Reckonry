{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerforge.org/schemas/ledgerforge-ledger-v1.schema.json",
  "title": "LedgerForge Canonical Ledger v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "metadata",
    "events"
  ],
  "properties": {
    "schemaVersion": {
      "const": "ledgerforge-ledger-v1"
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ledgerEvent"
      }
    }
  },
  "$defs": {
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "createdAtUtc",
        "generator",
        "eventCount"
      ],
      "properties": {
        "createdAtUtc": {
          "type": "string",
          "format": "date-time"
        },
        "generator": {
          "type": "string",
          "minLength": 1
        },
        "eventCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "ledgerEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "timestampUtc",
        "eventType",
        "description",
        "sourceReference",
        "postings"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "timestampUtc": {
          "type": "string",
          "format": "date-time"
        },
        "eventType": {
          "type": "string",
          "enum": [
            "Deposit",
            "Withdrawal",
            "Trade",
            "Conversion",
            "Reward",
            "Fee",
            "Transfer",
            "Unknown"
          ]
        },
        "description": {
          "type": "string"
        },
        "sourceReference": {
          "$ref": "#/$defs/sourceReference"
        },
        "postings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/posting"
          }
        }
      }
    },
    "posting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetSymbol",
        "amount",
        "direction",
        "account"
      ],
      "properties": {
        "assetSymbol": {
          "type": "string",
          "minLength": 1
        },
        "amount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "direction": {
          "type": "string",
          "enum": [
            "In",
            "Out"
          ]
        },
        "account": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "anyOf": [
            {
              "$ref": "#/$defs/money"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currencyCode",
        "amount"
      ],
      "properties": {
        "currencyCode": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "amount": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceSystem",
        "sourceFile",
        "sourceRowNumber",
        "rawData"
      ],
      "properties": {
        "sourceSystem": {
          "type": "string",
          "minLength": 1
        },
        "sourceFile": {
          "type": "string",
          "minLength": 1
        },
        "sourceRowNumber": {
          "type": "integer",
          "minimum": 1
        },
        "rawData": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
